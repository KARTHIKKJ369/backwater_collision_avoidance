# Copy this to .env and fill in your values
# .env is gitignored — never commit it

# --- Local dev (default) ---
MQTT_HOST=mqtt
MQTT_PORT=1883
VITE_API_BASE=http://localhost:8000
OPENWEATHER_API_KEY=your_key_here

# --- Pi deployment ---
# Uncomment and set these when deploying to Pi
# MQTT_HOST=localhost
# VITE_API_BASE=http://192.168.4.1:8000
